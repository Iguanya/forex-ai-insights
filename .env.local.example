# Example environment variables for local development
# Copy this file to .env.local and fill in your values

# TypeORM MySQL Database Connection (Frontend Direct Connection)
VITE_DB_HOST=144.172.93.6
VITE_DB_USER=root
VITE_DB_PASSWORD=your_mysql_password
VITE_DB_NAME=trading
VITE_DB_PORT=3306

# JWT Configuration (Frontend)
VITE_JWT_SECRET=your-secret-key-min-32-characters-long

# Forex Data Provider (optional - defaults to trying all configured providers)
# Options: "alpha_vantage", "twelve_data", "exchange_rate"
# Leave empty to use automatic fallback strategy
VITE_FOREX_DATA_PROVIDER=

# Optional: Set preferred refetch interval for live rates (in milliseconds)
# Alpha Vantage: 60000 (60 seconds) - has 5 calls/min limit
# Twelve Data: 5000 (5 seconds) - has 60 calls/min limit
# Default: 60000
VITE_FOREX_REFETCH_INTERVAL=60000

# Development Mode
VITE_MODE=development

